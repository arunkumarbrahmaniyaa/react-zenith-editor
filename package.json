{
  "name": "react-zenith-editor-monorepo",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter ./packages/* build",
